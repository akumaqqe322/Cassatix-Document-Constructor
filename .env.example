# App
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"

# Database (Prisma)
# Used by: apps/api
DATABASE_URL="postgresql://cassatix:password123@localhost:5432/legal_constructor?schema=public"

# Redis (BullMQ)
# Used by: apps/api, apps/worker
REDIS_HOST="localhost"
REDIS_PORT="6379"

# S3-compatible storage (MinIO)
# Used by: apps/api, apps/worker
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="documents"

# AI
# Required for Gemini AI API calls.
GEMINI_API_KEY=""
