# Railway Deployment Notes:
# 1. API Service: Set PORT (auto), DATABASE_URL (from Postgres), REDIS_HOST/PORT (from Redis), S3_*
# 2. Web Service: Set PORT (auto), API_URL (URL of the API service)
# 3. Worker Service: Set DATABASE_URL, REDIS_HOST/PORT, S3_*

# App Configuration
NODE_ENV="development"
PORT="3000"             # Port for the Web Frontend (Vite)
API_PORT="3001"         # Port for the Backend API (NestJS) - Local only, Railway uses PORT
API_URL="http://localhost:3001" # Used by Web service to find API service
APP_URL="http://localhost:3000"

# Database (Prisma)
# Railway provides DATABASE_URL automatically when you add a Postgres service
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# Redis (BullMQ)
# Railway provides REDIS_URL automatically when you add a Redis service
REDIS_URL="redis://default:password@host:port"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# S3-compatible storage (MinIO)
# Used for storing template files and generated documents
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="documents"
