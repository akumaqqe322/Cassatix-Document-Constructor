{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"web,api,worker\" -c \"blue,green,yellow\" \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:web": "vite apps/web --port 3000 --host 0.0.0.0",
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:worker": "tsx apps/worker/src/main.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build apps/web",
    "build:api": "echo 'API build not implemented'",
    "start": "concurrently -n \"web,api,worker\" -c \"blue,green,yellow\" \"npm run start:web\" \"npm run start:api\" \"npm run start:worker\"",
    "start:web": "vite preview apps/web --port 3000 --host 0.0.0.0",
    "start:api": "node apps/api/dist/main.js",
    "start:worker": "node apps/worker/dist/main.js",
    "clean": "rm -rf dist apps/web/dist",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@google/genai": "^1.29.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/client": "^6.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.96.2",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.0",
    "bullmq": "^5.73.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
